@page "/"
@using GsNetRobo.Data
@using GsNetRobo.Models
@using GsNetRobo.Services
@using Microsoft.EntityFrameworkCore
@inject ExcelReaderService ExcelReader
@inject JobQueueService JobQueue
@inject IDbContextFactory<AppDbContext> DbFactory
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>GSNet Robo - Automacao</PageTitle>

<h3 class="mb-4">Automacao GSNet</h3>

<div class="row">
    <div class="col-md-7">

        <!-- Credenciais -->
        <div class="card mb-3">
            <div class="card-header"><strong>Credenciais GSNet</strong></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Usuario</label>
                        <input type="text" class="form-control" @bind="usuario" placeholder="Usuario GSNet" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Senha</label>
                        <input type="password" class="form-control" @bind="senhaGsnet" placeholder="Senha GSNet" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Lotes -->
        @for (int i = 0; i < lotes.Count; i++)
        {
            var idx = i;
            var lote = lotes[i];
            <div class="card mb-3 border-primary">
                <div class="card-header d-flex justify-content-between align-items-center bg-primary bg-opacity-10">
                    <strong>Lote @(i + 1)</strong>
                    @if (lotes.Count > 1)
                    {
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoverLote(idx)">
                            &times; Remover
                        </button>
                    }
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Programa de Saude</label>
                            <select class="form-select" @bind="lote.ProgramaSaude">
                                <option value="">-- Selecione --</option>
                                @foreach (var p in programas)
                                {
                                    <option value="@p">@p</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tipo de Operacao</label>
                            <select class="form-select" @bind="lote.Operacao">
                                @foreach (OperationType op in Enum.GetValues<OperationType>())
                                {
                                    <option value="@op">@NomeOperacao(op)</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-1">
                        <label class="form-label">Planilha Excel (coluna A = numeros dos documentos)</label>
                        <InputFile class="form-control" OnChange="(e) => OnFileSelectedForLote(e, lote)" accept=".xlsx,.xls" />
                    </div>
                    @if (lote.Documentos.Count > 0)
                    {
                        <small class="text-success">
                            <strong>@lote.Documentos.Count</strong> documento(s) carregado(s) &mdash; @lote.NomeArquivo
                        </small>
                    }
                    @if (!string.IsNullOrEmpty(lote.ErroArquivo))
                    {
                        <small class="text-danger">@lote.ErroArquivo</small>
                    }
                </div>
            </div>
        }

        <div class="mb-3">
            <button class="btn btn-outline-secondary" @onclick="AdicionarLote">
                + Adicionar Lote
            </button>
        </div>

        @if (!string.IsNullOrEmpty(mensagemErro))
        {
            <div class="alert alert-danger">@mensagemErro</div>
        }

        <button class="btn btn-primary w-100" @onclick="Executar" disabled="@executando">
            @if (executando)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
                <span>Enviando...</span>
            }
            else
            {
                <span>Executar @(lotes.Count > 1 ? $"{lotes.Count} Lotes" : "Lote")</span>
            }
        </button>

        @if (mensagemSucesso != null)
        {
            <div class="alert alert-success mt-3">@mensagemSucesso</div>
        }
    </div>

    <div class="col-md-5">
        @if (jobAtivo != null)
        {
            <div class="card mb-3">
                <div class="card-header">
                    <strong>Job em Execucao #@jobAtivo.Id</strong>
                </div>
                <div class="card-body">
                    <p><strong>Operacao:</strong> @NomeOperacao(jobAtivo.OperationType)</p>
                    <p><strong>Programa:</strong> @jobAtivo.ProgramaSaude</p>
                    @if (!string.IsNullOrEmpty(jobAtivo.Gestor))
                    {
                        <p><strong>Gestor:</strong> @jobAtivo.Gestor</p>
                    }
                    <p><strong>Status:</strong>
                        <span class="badge @BadgeClass(jobAtivo.Status)">@jobAtivo.Status</span>
                    </p>
                    <div class="progress mb-2">
                        <div class="progress-bar" role="progressbar"
                             style="width: @Progresso()%"
                             aria-valuenow="@jobAtivo.DocumentosProcessados"
                             aria-valuemin="0"
                             aria-valuemax="@jobAtivo.TotalDocumentos">
                            @jobAtivo.DocumentosProcessados / @jobAtivo.TotalDocumentos
                        </div>
                    </div>
                    @if (jobAtivo.Status == JobStatus.Erro)
                    {
                        <div class="alert alert-danger mt-2">@jobAtivo.Erro</div>
                    }
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <strong>Ultimos Jobs</strong>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Operacao</th>
                            <th>Status</th>
                            <th>Progresso</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var j in ultimosJobs)
                        {
                            <tr>
                                <td>@j.Id</td>
                                <td>@NomeOperacao(j.OperationType)</td>
                                <td><span class="badge @BadgeClass(j.Status)">@j.Status</span></td>
                                <td>@j.DocumentosProcessados/@j.TotalDocumentos</td>
                            </tr>
                        }
                        @if (ultimosJobs.Count == 0)
                        {
                            <tr><td colspan="4" class="text-center text-muted">Nenhum job ainda</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private class LoteConfig
    {
        public string Gestor { get; set; } = string.Empty;
        public string ProgramaSaude { get; set; } = string.Empty;
        public OperationType Operacao { get; set; } = OperationType.Efetivar;
        public List<string> Documentos { get; set; } = new();
        public string? NomeArquivo { get; set; }
        public string? ErroArquivo { get; set; }
    }

    private List<LoteConfig> lotes = [new LoteConfig()];
    private string usuario = string.Empty;
    private string senhaGsnet = string.Empty;
    private bool executando;
    private string? mensagemErro;
    private string? mensagemSucesso;
    private AutomationJob? jobAtivo;
    private List<AutomationJob> ultimosJobs = new();
    private Timer? timer;

    private List<string> programas = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarProgramas();
        await CarregarUltimosJobs();
    }

    private async Task CarregarProgramas()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            programas = await db.ProgramasSaude.AsNoTracking()
                .Where(p => p.Ativo)
                .OrderBy(p => p.Nome)
                .Select(p => p.Nome)
                .ToListAsync();
        }
        catch { }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            timer = new Timer(async _ =>
            {
                await AtualizarProgresso();
                await InvokeAsync(StateHasChanged);
            }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
        }
    }

    private void AdicionarLote() => lotes.Add(new LoteConfig());

    private void RemoverLote(int idx)
    {
        if (lotes.Count > 1)
            lotes.RemoveAt(idx);
    }

    private async Task OnFileSelectedForLote(InputFileChangeEventArgs e, LoteConfig lote)
    {
        lote.ErroArquivo = null;
        lote.Documentos.Clear();
        lote.NomeArquivo = null;
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;
            lote.Documentos = ExcelReader.LerDocumentos(ms);
            lote.NomeArquivo = e.File.Name;
        }
        catch (Exception ex)
        {
            lote.ErroArquivo = $"Erro ao ler planilha: {ex.Message}";
        }
    }

    private async Task Executar()
    {
        mensagemErro = null;
        mensagemSucesso = null;

        if (string.IsNullOrWhiteSpace(usuario) || string.IsNullOrWhiteSpace(senhaGsnet))
        {
            mensagemErro = "Preencha usuario e senha do GSNet.";
            return;
        }

        for (int i = 0; i < lotes.Count; i++)
        {
            var lote = lotes[i];
            if (string.IsNullOrWhiteSpace(lote.Gestor))
            {
                mensagemErro = $"Lote {i + 1}: informe o Gestor.";
                return;
            }
            if (string.IsNullOrWhiteSpace(lote.ProgramaSaude))
            {
                mensagemErro = $"Lote {i + 1}: selecione o Programa de Saude.";
                return;
            }
            if (lote.Documentos.Count == 0)
            {
                mensagemErro = $"Lote {i + 1}: carregue uma planilha Excel com documentos.";
                return;
            }
        }

        executando = true;

        using var db = await DbFactory.CreateDbContextAsync();
        var idsEnfileirados = new List<int>();

        foreach (var lote in lotes)
        {
            var job = new AutomationJob
            {
                OperationType = lote.Operacao,
                ProgramaSaude = lote.ProgramaSaude,
                Gestor = lote.Gestor,
                TotalDocumentos = lote.Documentos.Count,
                Status = JobStatus.Pendente
            };

            db.Jobs.Add(job);
            await db.SaveChangesAsync();

            idsEnfileirados.Add(job.Id);
            jobAtivo = job;

            await JobQueue.EnfileirarAsync(new JobRequest
            {
                JobId = job.Id,
                Usuario = usuario,
                Senha = senhaGsnet,
                Documentos = new List<string>(lote.Documentos),
                Operacao = lote.Operacao,
                ProgramaSaude = lote.ProgramaSaude,
                Gestor = lote.Gestor
            });
        }

        var ids = string.Join(", #", idsEnfileirados);
        mensagemSucesso = $"Jobs #{ids} enfileirados com sucesso!";
        executando = false;

        await CarregarUltimosJobs();
    }

    private async Task AtualizarProgresso()
    {
        try
        {
            if (jobAtivo != null)
            {
                using var db = await DbFactory.CreateDbContextAsync();
                var atualizado = await db.Jobs.AsNoTracking().FirstOrDefaultAsync(j => j.Id == jobAtivo.Id);
                if (atualizado != null)
                {
                    jobAtivo = atualizado;
                    if (jobAtivo.Status == JobStatus.Concluido || jobAtivo.Status == JobStatus.Erro)
                    {
                        await CarregarUltimosJobs();
                    }
                }
            }
        }
        catch { }
    }

    private async Task CarregarUltimosJobs()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            ultimosJobs = await db.Jobs.AsNoTracking()
                .OrderByDescending(j => j.DataCriacao)
                .Take(10)
                .ToListAsync();
        }
        catch { }
    }

    private int Progresso()
    {
        if (jobAtivo == null || jobAtivo.TotalDocumentos == 0) return 0;
        return (int)((double)jobAtivo.DocumentosProcessados / jobAtivo.TotalDocumentos * 100);
    }

    private string NomeOperacao(OperationType op) => op switch
    {
        OperationType.Efetivar => "Efetivar",
        OperationType.Reservar => "Reservar",
        OperationType.EfetivarReservados => "Efetivar Reservados",
        OperationType.Deletar => "Deletar",
        OperationType.Desaprovar => "Desaprovar",
        _ => op.ToString()
    };

    private string BadgeClass(JobStatus status) => status switch
    {
        JobStatus.Pendente => "bg-secondary",
        JobStatus.Executando => "bg-primary",
        JobStatus.Concluido => "bg-success",
        JobStatus.Erro => "bg-danger",
        _ => "bg-secondary"
    };

    public void Dispose()
    {
        timer?.Dispose();
    }
}
